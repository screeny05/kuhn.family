<!doctype html>
<html lang="de">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Kuhn</title>
<style>
  :root{ --ink:#111; --paper:#f4f4f2; --red:#e8341c; }
  *{ box-sizing:border-box; margin:0; padding:0; }
  html,body{ height:100%; overflow:hidden; }
  body{ font-family:"Helvetica Neue", Arial, sans-serif; background:var(--paper); color:var(--ink);
    position:relative; }
  .type{ position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
    font-weight:700; letter-spacing:-.05em; line-height:.74; text-align:center;
    font-size:min(58vw, 60vh); white-space:nowrap; }
  .type .l2{ display:block; }
  .type .l2 i{ font-style:normal; color:var(--red); } /* the period */
  .tl{ position:absolute; top:clamp(18px,4vw,40px); left:clamp(18px,4vw,40px);
    font-size:13px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; }
  .br{ position:absolute; bottom:clamp(18px,4vw,40px); right:clamp(18px,4vw,40px);
    font-size:13px; font-weight:700; letter-spacing:.14em; text-transform:uppercase; text-align:right; }
  .br span{ color:#9b9b96; display:block; }
</style>
</head>
<body>
  <div class="type">KU<span class="l2">HN<i>.</i></span></div>
  <div class="br"><span>hallo@kuhn.family</span></div>
</body>
</html>